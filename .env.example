# Copy this file to .env and fill in your real credentials.

# Telegram / OpenClaw
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_GROUP_CHAT_ID=

# DeepSeek
DEEPSEEK_API_KEY=sk-replace_me
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Inventory bot safety
# 0 = Telegram/OpenClaw bridge blocks sales, stock updates, and cerrar dia.
# 1 = bridge can run confirmed mutations.
MUNDO_MATERNO_ALLOW_MUTATIONS=0

# OpenClaw agent routing
# Leave empty to use OpenClaw's default routed agent.
MUNDO_MATERNO_OPENCLAW_AGENT=
MUNDO_MATERNO_OPENCLAW_AGENT_TIMEOUT=600

# Database option A: SQLite
# Best for local testing or one computer.
MUNDO_MATERNO_DB_ENGINE=sqlite
# Optional. Relative paths are resolved from this project folder.
MUNDO_MATERNO_SQLITE_PATH=inventario.db

# Database option B: PostgreSQL
# Best for shared/server use. To use it, comment the sqlite line above,
# uncomment both lines below, and update DATABASE_URL.
# MUNDO_MATERNO_DB_ENGINE=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mundo_materno
